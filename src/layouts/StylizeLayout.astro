---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

type Props = {
  title: string;
  subtitle?: string;
  normalHref: string;
  backHref?: string;
  showBack?: boolean;
};

const {
  title,
  subtitle,
  normalHref,
  backHref = "/stylize",
  showBack = true,
} = Astro.props;
---

<Layout title={`${title} | Stylized | ${SITE.title}`}>
  <main id="main-content" class="stylize-page app-layout">
    <div class="stylize-controls">
      {
        showBack ? (
          <a
            href={backHref}
            class="stylize-back"
            aria-label="Back to stylized landing page"
            title="Back to stylized landing page"
          >
            <IconChevronLeft class="stylize-back__icon" />
          </a>
        ) : (
          <span aria-hidden="true" class="stylize-back stylize-back--ghost" />
        )
      }

      <a href={normalHref} class="stylize-normalise">Normalise</a>
    </div>

    <section>
      <h1 class="stylize-title">{title}</h1>
      {subtitle && <p class="stylize-subtitle">{subtitle}</p>}
      <div class="stylize-content">
        <slot />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .stylize-page {
    padding-top: 1.5rem;
    padding-bottom: 4rem;
  }

  .stylize-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stylize-back,
  .stylize-normalise {
    font-family: var(--font-mono), monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--foreground);
    text-decoration: none;
  }

  .stylize-back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
  }

  .stylize-back--ghost {
    opacity: 0;
    pointer-events: none;
  }

  .stylize-back__icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  .stylize-normalise {
    padding: 0.45rem 0.8rem;
  }

  .stylize-back:hover,
  .stylize-normalise:hover {
    border-color: var(--foreground);
  }

  .stylize-title {
    font-size: 2rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .stylize-subtitle {
    font-family: var(--font-mono), monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-bottom: 1.9rem;
  }

  @media (max-width: 640px) {
    .stylize-page {
      padding-top: 1rem;
      padding-bottom: 3rem;
    }
  }
</style>
