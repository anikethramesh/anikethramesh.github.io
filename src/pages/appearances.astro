---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`Appearances | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <section
      id="appearances"
      class="app-prose mb-28 max-w-app prose-img:border-0"
    >
      <h1 class="text-2xl tracking-wider sm:text-3xl">Appearances</h1>

      <p>Talks, podcasts, interviews, and other public appearances.</p>

      <h2>Talks</h2>
      <ul>
        <li>
          <a href="#">Talk Title</a> — Event Name, Year
        </li>
      </ul>

      <h2>Podcasts</h2>
      <ul>
        <li>
          <a href="#">Episode Title</a> — Podcast Name, Year
        </li>
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
