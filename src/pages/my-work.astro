---
// Content lives in src/data/work/my-work.md — edit there, not here.
// Styles are applied to native HTML elements rendered from the markdown.
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const entry = await getEntry("work", "my-work");
if (!entry) throw new Error("my-work.md not found in src/data/work/");
const { Content } = await render(entry);
---

<Layout title={`My Work | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <section id="my-work" class="work-section">
      <h1 class="page-title">My Career in Robotics</h1>
      <p class="page-subtitle">What I've built and where</p>
      <div class="work-content">
        <Content />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .work-section { padding-top: 3.5rem; padding-bottom: 4rem; }

  .page-title { font-size: 2rem; font-weight: 500; margin-bottom: 0.25rem; }
  .page-subtitle {
    font-family: var(--font-mono), monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-bottom: 1.9rem;
  }

  /* Styles for rendered markdown content */
  :global(.work-content p) {
    font-size: 1.05rem;
    line-height: 1.68;
    margin-bottom: 0.9rem;
  }

  :global(.work-content h2) {
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 1rem;
    margin-top: 0;
    color: var(--foreground);
  }

  /* Subsection title (###) */
  :global(.work-content h3) {
    font-family: var(--font-mono), monospace;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 400;
    margin-bottom: 0.25rem;
    margin-top: 0;
    color: var(--foreground);
  }

  /* Subsection meta (####) */
  :global(.work-content h4) {
    font-family: var(--font-mono), monospace;
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--muted);
    margin-bottom: 1rem;
    margin-top: 0;
  }

  :global(.work-content hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-top: 2rem;
    margin-bottom: 1.5rem;
  }

  /* Blockquote — emphasis callout */
  :global(.work-content blockquote) {
    border-left: 2px solid var(--border);
    padding-left: 1rem;
    margin: 0 0 0.9rem;
  }

  :global(.work-content blockquote p) {
    margin-bottom: 0;
  }

  /* Bold-only paragraph — acts as a mono label before a list */
  :global(.work-content p:has(> strong:only-child)) {
    font-family: var(--font-mono), monospace;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }

  :global(.work-content strong) {
    font-weight: inherit;
  }

  :global(.work-content ul) {
    list-style: none;
    padding: 0 0 0.85rem 1rem;
    margin: 0 0 0.85rem;
    border-left: 2px solid var(--border);
  }

  :global(.work-content li) {
    font-size: 1.05rem;
    line-height: 1.68;
    padding: 0.08rem 0;
  }

  :global(.work-content a) {
    color: var(--foreground);
    text-decoration: underline;
  }

  :global(.work-content a:hover) {
    text-decoration: none;
  }
</style>
