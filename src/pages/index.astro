---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
// Homepage content is in src/data/homepage.ts — edit there, not here.
import { HOMEPAGE } from "@/data/homepage";
---

<Layout title={SITE.title}>
  <Header />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="home-name">{HOMEPAGE.name}</h1>
      <p class="home-tagline">{HOMEPAGE.tagline}</p>
      {HOMEPAGE.bio.map(paragraph => <p>{paragraph}</p>)}
      {
        SOCIALS.length > 0 && (
          <div class="mt-6 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap text-foreground sm:mb-0">
              Find me on:
            </div>
            <Socials />
          </div>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .home-name {
    font-family: var(--font-body), Georgia, serif;
    font-size: 2rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .home-tagline {
    font-family: var(--font-mono), monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-bottom: 2rem;
  }
</style>
