---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
---

<Layout title={SITE.title}>
  <Header />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">About</h1>
      <p>
        I build things that work in challenging environments with minimal
        supervision, without hand-holding. My work sits at the intersection of
        autonomy, robotics, and the uncomfortable edge cases that only show up
        in the field. 
      </p>
      <p>
        PhD at the Extreme Robotics Lab, University of Birmingham — four years
        figuring out how robots, AIs and humans can work as actual teams.
        Robot Vitals framework and 8 peer-reviewed papers. 
      </p>
      <p>
        Co-founded and exited as CTO of Occam Industries, a hypergrowth defence tech startup
        that is currently deploying autonomous AI pilots for UAVs. 
        Now looking for my next opportunity.
      </p>

      <p>
        As an Avid Reddit and X lurker, I like geeking out about history and philosophy. 
        Also, I'd like to think I can cook and play music really well. 
      </p>

      {
        SOCIALS.length > 0 && (
          <div class="mt-6 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Find me on:</div>
            <Socials />
          </div>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>
