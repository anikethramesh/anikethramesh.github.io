---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import Datetime from "@/components/Datetime.astro";
import { SITE } from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`Occasional Writing | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <section id="blog" class="blog-section">
      <h1 class="page-title">Occasional Writing</h1>
      <p class="page-subtitle">
        I write to formalise my thinking. Topic-agnostic. Posted occasionally.
      </p>

      <ul class="post-list">
        {
          page.data.map(post => (
            <li class="post-item">
              <h2 class="item-title">
                <a href={getPath(post.id, post.filePath)}>{post.data.title}</a>
              </h2>
              <Datetime
                pubDatetime={post.data.pubDatetime}
                modDatetime={post.data.modDatetime}
                timezone={post.data.timezone}
                class="post-date font-mono-ui"
              />
              <p class="body-text">{post.data.description}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>

<style>
  .blog-section {
    padding-top: 3.5rem;
    padding-bottom: 4rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .page-subtitle {
    font-family: var(--font-mono), monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-bottom: 1.9rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    padding: 0 0 0.85rem 1rem;
    margin-bottom: 0.85rem;
    border-left: 2px solid var(--border);
  }

  .post-item:last-child {
    margin-bottom: 0;
  }

  .item-title {
    font-family: var(--font-mono), monospace;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }

  .item-title a {
    text-decoration: none;
  }

  .item-title a:hover {
    text-decoration: underline;
  }

  .post-date {
    margin-bottom: 0.35rem;
    color: var(--muted);
  }

  .post-date :global(svg) {
    width: 0.95rem;
    height: 0.95rem;
  }

  .post-date :global(time),
  .post-date :global(span) {
    font-size: 0.72rem;
  }

  .body-text {
    font-size: 1.05rem;
    line-height: 1.68;
    margin-bottom: 0;
  }
</style>
