---
import { getCollection } from "astro:content";
import Datetime from "@/components/Datetime.astro";
import StylizeLayout from "@/layouts/StylizeLayout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
---

<StylizeLayout
  title="Occasional Writing"
  subtitle="Topic-agnostic notes, essays, and half-finished obsessions"
  normalHref="/blog"
>
  <section class="stylize-blog">
    <p class="intro-copy">
      Browse the headlines here, then drop into the standard reading view for
      the full article.
    </p>

    <ul class="post-list">
      {
        sortedPosts.map(post => (
          <li class="post-item">
            <h2 class="item-title">
              <a href={getPath(post.id, post.filePath)}>{post.data.title}</a>
            </h2>
            <Datetime
              pubDatetime={post.data.pubDatetime}
              modDatetime={post.data.modDatetime}
              timezone={post.data.timezone}
              class="post-date font-mono-ui"
            />
            <p>{post.data.description}</p>
          </li>
        ))
      }
    </ul>
  </section>
</StylizeLayout>

<style>
  .intro-copy {
    font-size: 1.02rem;
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    padding-left: 1rem;
    border-left: 2px solid var(--border);
  }

  .post-item + .post-item {
    margin-top: 1rem;
    padding-top: 1rem;
  }

  .item-title {
    font-family: var(--font-mono), monospace;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.3rem;
  }

  .post-date {
    margin-bottom: 0.35rem;
    color: var(--muted);
  }

  .post-date :global(svg) {
    width: 0.95rem;
    height: 0.95rem;
  }

  .post-date :global(time),
  .post-date :global(span) {
    font-size: 0.72rem;
  }

  .post-item p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }
</style>
