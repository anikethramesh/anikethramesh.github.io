---
import StylizeLayout from "@/layouts/StylizeLayout.astro";
import { HOMEPAGE } from "@/data/homepage";
---

<StylizeLayout title={HOMEPAGE.name} subtitle={HOMEPAGE.tagline} normalHref="/">
  <section class="stylize-prose">
    {HOMEPAGE.bio.map(paragraph => <p>{paragraph}</p>)}
  </section>
</StylizeLayout>

<style>
  .stylize-prose p {
    font-size: 1.08rem;
    line-height: 1.7;
    margin: 0 0 1rem;
  }

  .stylize-prose p:last-child {
    margin-bottom: 0;
  }
</style>
