---
import { getCollection } from "astro:content";
import StylizeLayout from "@/layouts/StylizeLayout.astro";

const issues = await getCollection("zine");
const [currentIssue] = issues.sort(
  (a, b) => b.data.sortDate.getTime() - a.data.sortDate.getTime()
);

if (!currentIssue) {
  throw new Error(
    "No zine issue found. Add a markdown file under src/data/zine."
  );
}

const { reading, worthReading, thought, listening, local } = currentIssue.data;

const toSpotifyEmbedUrl = (url?: string) => {
  if (!url) return undefined;

  try {
    const parsedUrl = new URL(url);
    if (!parsedUrl.hostname.includes("spotify.com")) return undefined;
    if (parsedUrl.pathname.includes("/embed/")) return url;

    const segments = parsedUrl.pathname.split("/").filter(Boolean);
    if (segments.length < 2) return undefined;

    const [type, id] = segments;
    return `https://open.spotify.com/embed/${type}/${id}`;
  } catch {
    return undefined;
  }
};

const listeningEmbedUrl = toSpotifyEmbedUrl(listening.spotifyUrl);
---

<StylizeLayout
  title="Zine"
  subtitle={`${currentIssue.data.issueLabel} · ${currentIssue.data.issueDate}`}
  normalHref="/zine"
>
  <section class="stylize-zine">
    <p class="issue-note">{currentIssue.data.subtitle}</p>

    <section aria-labelledby="stylize-reading" class="zine-block">
      <p id="stylize-reading" class="section-label">Currently reading</p>
      <div class="reading-header">
        {
          reading.image && (
            <figure class="reading-thumb-block">
              <img
                src={reading.image.src}
                alt={reading.image.alt}
                class="reading-thumb"
              />
              {reading.image.caption && (
                <figcaption class="media-caption">
                  {reading.image.caption}
                </figcaption>
              )}
            </figure>
          )
        }

        <div class="reading-copy">
          {
            reading.title &&
              (reading.href ? (
                <h2 class="item-title">
                  <a
                    href={reading.href}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {reading.title}
                  </a>
                </h2>
              ) : (
                <h2 class="item-title">{reading.title}</h2>
              ))
          }
          {reading.meta && <p class="item-meta">{reading.meta}</p>}
        </div>
      </div>
      {reading.description && <p class="body-copy">{reading.description}</p>}
    </section>

    <section aria-labelledby="stylize-worth-reading" class="zine-block">
      <p id="stylize-worth-reading" class="section-label">Worth reading</p>
      {
        worthReading.title &&
          (worthReading.href ? (
            <h2 class="item-title">
              <a
                href={worthReading.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {worthReading.title}
              </a>
            </h2>
          ) : (
            <h2 class="item-title">{worthReading.title}</h2>
          ))
      }
      {worthReading.meta && <p class="item-meta">{worthReading.meta}</p>}
      {
        worthReading.image && (
          <figure class="media-block">
            <img
              src={worthReading.image.src}
              alt={worthReading.image.alt}
              class="media-image"
            />
            {worthReading.image.caption && (
              <figcaption class="media-caption">
                {worthReading.image.caption}
              </figcaption>
            )}
          </figure>
        )
      }
      {
        worthReading.description && (
          <p class="body-copy">{worthReading.description}</p>
        )
      }
      {
        worthReading.href && worthReading.linkLabel && (
          <p class="link-row">
            <a
              href={worthReading.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              {worthReading.linkLabel}
            </a>
          </p>
        )
      }
    </section>

    <section
      aria-labelledby="stylize-thought"
      class="zine-block zine-block--quote"
    >
      <p id="stylize-thought" class="section-label">A thought</p>
      <blockquote class="quote-text">
        <p>"{thought.quote}"</p>
      </blockquote>
      <p class="quote-attribution">{thought.attribution}</p>
    </section>

    <section aria-labelledby="stylize-listening" class="zine-block">
      <p id="stylize-listening" class="section-label">Listening to</p>
      {
        listening.title &&
          (listening.href ? (
            <h2 class="item-title">
              <a
                href={listening.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {listening.title}
              </a>
            </h2>
          ) : (
            <h2 class="item-title">{listening.title}</h2>
          ))
      }
      {listening.meta && <p class="item-meta">{listening.meta}</p>}
      {
        listeningEmbedUrl && (
          <div class="spotify-embed">
            <iframe
              src={listeningEmbedUrl}
              width="100%"
              height="152"
              style="border: 0;"
              allowfullscreen
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
              title={`Spotify embed for ${listening.title ?? "playlist"}`}
            />
          </div>
        )
      }
      {
        listening.image && (
          <figure class="media-block">
            <img
              src={listening.image.src}
              alt={listening.image.alt}
              class="media-image"
            />
            {listening.image.caption && (
              <figcaption class="media-caption">
                {listening.image.caption}
              </figcaption>
            )}
          </figure>
        )
      }
      {
        listening.description && (
          <p class="body-copy">{listening.description}</p>
        )
      }
    </section>

    <section aria-labelledby="stylize-local" class="zine-block">
      <p id="stylize-local" class="section-label">London right now</p>
      {
        local.image && (
          <figure class="media-block">
            <img
              src={local.image.src}
              alt={local.image.alt}
              class="media-image"
            />
            {local.image.caption && (
              <figcaption class="media-caption">
                {local.image.caption}
              </figcaption>
            )}
          </figure>
        )
      }
      {local.description && <p class="body-copy">{local.description}</p>}
    </section>
  </section>
</StylizeLayout>

<style>
  .issue-note {
    font-size: 1.04rem;
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }

  .zine-block + .zine-block {
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-mono), monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.85rem;
  }

  .reading-header {
    display: grid;
    grid-template-columns: minmax(0, 160px) minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .reading-thumb-block,
  .media-block {
    margin: 0 0 1rem;
  }

  .reading-thumb,
  .media-image {
    width: 100%;
    display: block;
    border: 1px solid var(--border);
  }

  .media-caption {
    font-family: var(--font-mono), monospace;
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.4rem;
  }

  .item-title {
    font-size: 1.35rem;
    line-height: 1.15;
    margin: 0 0 0.25rem;
  }

  .item-meta {
    font-family: var(--font-mono), monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0;
  }

  .body-copy {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  .quote-text {
    margin: 0 0 0.75rem;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
    font-size: 1.2rem;
    line-height: 1.45;
  }

  .quote-text p,
  .quote-attribution {
    margin: 0;
  }

  .quote-attribution {
    font-family: var(--font-mono), monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .spotify-embed {
    margin: 0.9rem 0 1rem;
  }

  .link-row {
    margin: 0.9rem 0 0;
    font-family: var(--font-mono), monospace;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 640px) {
    .reading-header {
      grid-template-columns: 1fr;
    }
  }
</style>
