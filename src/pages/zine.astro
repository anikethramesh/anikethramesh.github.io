---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`Zine | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout">
    <section id="zine" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">Zine</h1>

      <p>
        A deliberate, curated snapshot — not a live feed. Things I'm reading,
        listening to, and thinking about.
      </p>

      <h2>Currently Reading</h2>
      <ul>
        <li>[Book or article title] — [Author]</li>
      </ul>

      <h2>Listening</h2>
      <ul>
        <li>[Playlist or album] — [Artist / Link]</li>
      </ul>

      <h2>Thoughts</h2>
      <p>[A loose idea, observation, or fragment worth preserving.]</p>
    </section>
  </main>
  <Footer />
</Layout>
