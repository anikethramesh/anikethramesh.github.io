---
// Stylize mode overlay.
// Activated by adding `stylize-active` class to <body>.
// Assets must live in public/collage/:
//   collage_bw.jpg  — base greyscale photo (480×637)
//   Bio.png         → / (about)
//   TV.png          → /appearances
//   Zine.png        → /zine
//   Blog.png        → /blog
//   Couch.png       → light/dark theme toggle
---

<div
  id="stylize-overlay"
  aria-hidden="true"
  role="dialog"
  aria-label="Stylize navigation"
>
  <!-- Masthead -->
  <div class="masthead">
    <div class="masthead-rule"></div>
    <h2 class="masthead-title">The Aniketh Ramesh Chronicle</h2>
    <p class="masthead-sub">
      Est. 1994 &middot; All the news that fits to print
    </p>
    <div class="masthead-rule"></div>
  </div>

  <!-- Collage -->
  <div class="collage-wrap">
    <p class="collage-hint">hover to explore</p>
    <div class="collage" id="collage">
      <!-- Base image — greyscale -->
      <img
        class="layer-base"
        src="/collage/collage_bw.jpg"
        alt="Aniketh's room"
        draggable="false"
      />

      <!-- Colour cutouts — revealed on pixel-accurate hover -->
      <img
        class="layer-cutout"
        id="cut-bio"
        src="/collage/Bio.png"
        alt=""
        draggable="false"
        crossorigin="anonymous"
      />
      <img
        class="layer-cutout"
        id="cut-tv"
        src="/collage/TV.png"
        alt=""
        draggable="false"
        crossorigin="anonymous"
      />
      <img
        class="layer-cutout"
        id="cut-zine"
        src="/collage/Zine.png"
        alt=""
        draggable="false"
        crossorigin="anonymous"
      />
      <img
        class="layer-cutout"
        id="cut-couch"
        src="/collage/Couch.png"
        alt=""
        draggable="false"
        crossorigin="anonymous"
      />
      <img
        class="layer-cutout"
        id="cut-blog"
        src="/collage/Blog.png"
        alt=""
        draggable="false"
        crossorigin="anonymous"
      />

      <!-- Tooltips — positioned at fixed % coordinates, shown by JS -->
      <span class="tip" id="tip-bio" style="left: 44%; top: 48%;">About me</span
      >
      <span class="tip" id="tip-tv" style="left: 46%; top: 26%;"
        >Appearances</span
      >
      <span class="tip" id="tip-zine" style="left: 80%; top: 33%;">Zine</span>
      <span class="tip" id="tip-blog" style="left: 52%; top: 8%;">Blog</span>
      <span class="tip" id="tip-couch" style="left: 10%; top: 70%;"
        >Toggle Dark Mode</span
      >

      <!-- Single transparent hit-detection layer on top -->
      <div id="collage-hit" class="collage-hit"></div>
    </div>
  </div>

  <!-- Normalise button -->
  <button
    id="normalise-btn"
    class="normalise-btn"
    aria-label="Exit stylize mode"
  >
    &#x2715; Normalise
  </button>
</div>

<style>
  /* ── Overlay shell ── */
  #stylize-overlay {
    --stylize-bg: #f0ebe0;
    --stylize-title: #1a1a1a;
    --stylize-rule: #1a1a1a;
    --stylize-sub: #555;
    --stylize-hint: #999;
    --stylize-tip-bg: #1a1a1a;
    --stylize-tip-text: #f5de00;
    --stylize-close: #c0392b;
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--stylize-bg);
    padding: 1rem 1rem 2rem;
    overflow-y: auto;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.25s ease,
      background-color 0.25s ease;
  }

  html[data-theme="dark"] #stylize-overlay {
    --stylize-bg: #151515;
    --stylize-title: #f7f5f0;
    --stylize-rule: #f7f5f0;
    --stylize-sub: #d1cabd;
    --stylize-hint: #aca395;
    --stylize-tip-bg: #f7f5f0;
    --stylize-tip-text: #1a1a1a;
    --stylize-close: #f2a095;
  }

  body.stylize-active #stylize-overlay {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Masthead ── */
  .masthead {
    text-align: center;
    margin-bottom: 1rem;
    width: 100%;
    max-width: 480px;
  }

  .masthead-rule {
    border-top: 2px solid var(--stylize-rule);
    margin: 0.35rem 0;
    transition: border-color 0.25s ease;
  }

  .masthead-title {
    font-family: "EB Garamond", Georgia, serif;
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--stylize-title);
    line-height: 1.1;
    margin: 0.3rem 0;
    letter-spacing: 0.02em;
    transition: color 0.25s ease;
  }

  .masthead-sub {
    font-family: "Space Mono", monospace;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--stylize-sub);
    margin: 0.2rem 0;
    transition: color 0.25s ease;
  }

  /* ── Hint ── */
  .collage-hint {
    font-family: "Space Mono", monospace;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--stylize-hint);
    text-align: center;
    margin-bottom: 0.7rem;
    transition: color 0.25s ease;
  }

  /* ── Collage container ── */
  .collage-wrap {
    width: 100%;
    max-width: 480px;
  }

  .collage {
    position: relative;
    width: 100%;
    aspect-ratio: 480 / 637;
  }

  /* All layers stack on the same canvas */
  .collage img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    pointer-events: none;
  }

  /* Base: greyscale/sepia */
  .layer-base {
    z-index: 1;
    filter: grayscale(100%) sepia(15%) contrast(1.05) brightness(0.92);
  }

  /* Cutouts: invisible by default, JS adds .active class */
  .layer-cutout {
    z-index: 2;
    opacity: 0;
    transition: opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    filter: drop-shadow(0 4px 18px rgba(0, 0, 0, 0.2));
  }

  .layer-cutout.active {
    opacity: 1;
  }

  /* ── Tooltips ── */
  .tip {
    position: absolute;
    transform: translateX(-50%) translateY(-100%);
    margin-top: -10px;
    background: var(--stylize-tip-bg);
    color: var(--stylize-tip-text);
    font-family: "Space Mono", monospace;
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    white-space: nowrap;
    z-index: 20;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 0.15s,
      background-color 0.25s ease,
      color 0.25s ease;
  }

  .tip::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: var(--stylize-tip-bg);
    transition: border-top-color 0.25s ease;
  }

  .tip.active {
    opacity: 1;
  }

  /* Transparent hit layer sits on top of everything */
  .collage-hit {
    position: absolute;
    inset: 0;
    z-index: 10;
    cursor: crosshair;
  }

  /* ── Normalise button ── */
  .normalise-btn {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    font-family: "Space Mono", monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--stylize-close);
    background: none;
    border: 1.5px solid var(--stylize-close);
    padding: 5px 12px;
    cursor: pointer;
    transition:
      background-color 0.15s,
      color 0.15s,
      border-color 0.15s;
    z-index: 1001;
  }

  .normalise-btn:hover {
    background: var(--stylize-close);
    color: #fff;
  }
</style>

<script>
  // Canvas dimensions match the PNG assets
  const W = 480;
  const H = 637;

  // Map cutout id → { nav action, tip id }
  const CUTOUTS = [
    { cutId: "cut-bio", tipId: "tip-bio", action: () => navigate("/") },
    {
      cutId: "cut-tv",
      tipId: "tip-tv",
      action: () => navigate("/appearances"),
    },
    { cutId: "cut-zine", tipId: "tip-zine", action: () => navigate("/zine") },
    { cutId: "cut-blog", tipId: "tip-blog", action: () => navigate("/blog") },
    { cutId: "cut-couch", tipId: "tip-couch", action: () => toggleTheme() },
  ];

  // Offscreen canvases holding pixel data for each PNG
  const pixelData: Record<string, ImageData> = {};

  function navigate(href: string) {
    exitStylize();
    window.location.href = href;
  }

  function toggleTheme() {
    const current = document.documentElement.getAttribute("data-theme");
    const next = current === "dark" ? "light" : "dark";
    (window as any).theme?.setTheme(next);
    (window as any).theme?.setPreference?.();
    syncThemeCopy();
  }

  function syncThemeCopy() {
    const tip = document.getElementById("tip-couch");
    if (!tip) return;

    const current = document.documentElement.getAttribute("data-theme");
    tip.textContent =
      current === "dark" ? "Toggle Light Mode" : "Toggle Dark Mode";
  }

  function exitStylize() {
    document.body.classList.remove("stylize-active");
    document
      .getElementById("stylize-overlay")
      ?.setAttribute("aria-hidden", "true");
    clearActive();
  }

  function enterStylize() {
    document.body.classList.add("stylize-active");
    document
      .getElementById("stylize-overlay")
      ?.setAttribute("aria-hidden", "false");
    syncThemeCopy();
  }

  function clearActive() {
    CUTOUTS.forEach(({ cutId, tipId }) => {
      document.getElementById(cutId)?.classList.remove("active");
      document.getElementById(tipId)?.classList.remove("active");
    });
  }

  // Load a PNG into an offscreen canvas and store its ImageData
  function loadPixelData(cutId: string, src: string): Promise<void> {
    return new Promise(resolve => {
      const img = new Image();
      img.crossOrigin = "anonymous";
      img.onload = () => {
        const canvas = document.createElement("canvas");
        canvas.width = W;
        canvas.height = H;
        const ctx = canvas.getContext("2d")!;
        ctx.drawImage(img, 0, 0, W, H);
        try {
          pixelData[cutId] = ctx.getImageData(0, 0, W, H);
        } catch {
          // Canvas tainted or unavailable — fall back to no pixel testing
        }
        resolve();
      };
      img.onerror = () => resolve(); // don't block if asset missing
      img.src = src;
    });
  }

  function isHit(cutId: string, x: number, y: number): boolean {
    const data = pixelData[cutId];
    if (!data) return false;
    const px = Math.floor(x);
    const py = Math.floor(y);
    if (px < 0 || py < 0 || px >= W || py >= H) return false;
    const alpha = data.data[(py * W + px) * 4 + 3];
    return alpha > 15; // ignore near-transparent anti-alias fringe
  }

  async function preloadAll() {
    await Promise.all(
      CUTOUTS.map(({ cutId }) => {
        const el = document.getElementById(cutId) as HTMLImageElement | null;
        if (el?.src) return loadPixelData(cutId, el.src);
        return Promise.resolve();
      })
    );
  }

  let currentHit: string | null = null;

  function setupHitDetection() {
    const hitLayer = document.getElementById("collage-hit");
    if (!hitLayer) return;

    hitLayer.addEventListener("mousemove", (e: Event) => {
      const ev = e as MouseEvent;
      const rect = (hitLayer as HTMLElement).getBoundingClientRect();
      const scaleX = W / rect.width;
      const scaleY = H / rect.height;
      const x = (ev.clientX - rect.left) * scaleX;
      const y = (ev.clientY - rect.top) * scaleY;

      let hit: string | null = null;
      for (const { cutId } of CUTOUTS) {
        if (isHit(cutId, x, y)) {
          hit = cutId;
          break; // first match wins (z-order: bio > tv > zine > blog > couch)
        }
      }

      if (hit === currentHit) return; // no change
      clearActive();
      currentHit = hit;

      if (hit) {
        document.getElementById(hit)?.classList.add("active");
        const entry = CUTOUTS.find(c => c.cutId === hit)!;
        document.getElementById(entry.tipId)?.classList.add("active");
        (hitLayer as HTMLElement).style.cursor = "pointer";
      } else {
        (hitLayer as HTMLElement).style.cursor = "crosshair";
      }
    });

    hitLayer.addEventListener("mouseleave", () => {
      clearActive();
      currentHit = null;
    });

    hitLayer.addEventListener("click", () => {
      if (!currentHit) return;
      const entry = CUTOUTS.find(c => c.cutId === currentHit);
      entry?.action();
    });
  }

  function init() {
    document
      .getElementById("normalise-btn")
      ?.addEventListener("click", exitStylize);
    document
      .getElementById("stylize-btn")
      ?.addEventListener("click", enterStylize);

    document.addEventListener("astro:before-swap", exitStylize);

    document.addEventListener("keydown", (e: KeyboardEvent) => {
      if (
        e.key === "Escape" &&
        document.body.classList.contains("stylize-active")
      ) {
        exitStylize();
      }
    });

    syncThemeCopy();
    setupHitDetection();
    preloadAll();
  }

  document.addEventListener("astro:page-load", init);
</script>
