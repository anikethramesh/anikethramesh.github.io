---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import { SITE } from "@/config"; // used for lightAndDarkMode flag

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};

const navLinks = [
  { href: "/", label: "About" },
  { href: "/my-work", label: "My Work" },
  { href: "/appearances", label: "Appearances" },
  { href: "/blog", label: "Blog" },
  { href: "/zine", label: "Zine" },
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header class="app-layout">
  <div
    id="top-nav-wrap"
    style="padding-top: 2rem; padding-bottom: 1.5rem; display: flex; align-items: center; justify-content: flex-end;"
  >
    <nav
      style="display: flex; flex-wrap: wrap; align-items: center; gap: 0 2rem;"
    >
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            style={`font-family: var(--font-mono), monospace; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; text-decoration: none; color: ${isActive(href) ? "var(--foreground)" : "var(--muted)"}; transition: color 0.15s;`}
          >
            {label}
          </a>
        ))
      }
      <a
        href="/stylize"
        title="Stylize"
        aria-label="Enter stylized mode"
        style="font-family: var(--font-mono), monospace; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; background: none; border: 1px solid var(--border); color: var(--muted); padding: 2px 8px; cursor: pointer; transition: color 0.15s, border-color 0.15s; text-decoration: none;"
        onmouseover="this.style.color='var(--foreground)'; this.style.borderColor='var(--foreground)';"
        onmouseout="this.style.color='var(--muted)'; this.style.borderColor='var(--border)';"
      >
        Stylize
      </a>

      {
        SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="focus-outline"
            style="position: relative; width: 1.2rem; height: 1.2rem; background: none; border: none; padding: 0; color: var(--muted); cursor: pointer;"
            title="Toggles light & dark"
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon
              width={14}
              height={14}
              style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(1) rotate(0deg); transition: all 0.2s;"
              class="dark-hide"
            />
            <IconSunHigh
              width={14}
              height={14}
              style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0) rotate(90deg); transition: all 0.2s;"
              class="dark-show"
            />
          </button>
        )
      }
    </nav>
  </div>
</header>

<style>
  html[data-theme="dark"] .dark-hide {
    transform: translate(-50%, -50%) scale(0) rotate(-90deg) !important;
  }
  html[data-theme="dark"] .dark-show {
    transform: translate(-50%, -50%) scale(1) rotate(0deg) !important;
  }
</style>
